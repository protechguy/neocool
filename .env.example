# All variables below are REQUIRED. The server throws on first request to
# /api/order if any are missing or malformed (src/lib/env.ts).

# SMTP server used to deliver order request emails to the operator.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=orders@example.com
SMTP_PASS=change-me

# Mailbox that receives submitted order requests.
ORDER_EMAIL_TO=ops@example.com
